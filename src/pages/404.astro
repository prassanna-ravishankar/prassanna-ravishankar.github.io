---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
---

<Layout title="Page Not Found | Prassanna Ravishankar" description="The page you're looking for doesn't exist. Explore other content on Prassanna Ravishankar's website.">
  <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 text-center">
      <div>
        <h1 class="text-9xl font-bold text-main/20">404</h1>
        <h2 class="mt-6 text-3xl font-extrabold text-main">
          Page not found
        </h2>
        <p class="mt-2 text-sm text-muted">
          Sorry, we couldn't find the page you're looking for.
        </p>
      </div>

      <div class="mt-8 flex flex-col space-y-3">
        <Button href="/" variant="primary" class="w-full justify-center">
          Go back home
        </Button>
        <Button href="/blog/" variant="secondary" class="w-full justify-center">
          Browse blog posts
        </Button>
        <Button href="/projects/" variant="secondary" class="w-full justify-center">
          View projects
        </Button>
      </div>

      <div class="mt-8">
        <p class="text-sm text-muted">
          Or search for what you're looking for:
        </p>
        <div class="mt-2 flex rounded-md shadow-sm">
          <input
            type="text"
            id="search-input"
            class="flex-1 min-w-0 block w-full px-3 py-2 rounded-l-md border border-subtle/20 bg-surface text-main focus:ring-primary focus:border-primary sm:text-sm"
            placeholder="Search content..."
          />
          <button
            type="button"
            id="search-button"
            class="inline-flex items-center px-3 py-2 rounded-r-md border border-l-0 border-subtle/20 bg-surface text-muted hover:bg-subtle/10 focus:outline-none focus:ring-2 focus:ring-primary transition-colors"
          >
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchButton = document.getElementById('search-button') as HTMLButtonElement;
    if (!searchInput || !searchButton) return;

    function performSearch() {
      const query = searchInput.value.trim();
      if (query) {
        window.location.href = `https://www.google.com/search?q=site:prassanna.io ${encodeURIComponent(query)}`;
      }
    }

    searchButton.addEventListener('click', performSearch);
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        performSearch();
      }
    });
  });
</script> 